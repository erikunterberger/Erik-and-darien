<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>League Standard – Fan Sign-Up</title>

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <link rel="stylesheet" href="css/styles.css" />
</head>

<body class="bg-light">

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="index.html">League Standard</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="index.html">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="signup.html">Fan Sign-Up</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- HEADER -->
  <header class="text-center py-5 bg-primary text-white">
    <h1 class="fw-bold">Join League Standard</h1>
    <p class="lead">Track your favorite NBA teams and players with ease.</p>
  </header>

  <!-- MAIN CONTENT -->
  <main class="container my-5">

    <h2 class="mb-4">Fan Registration</h2>

    <form id="memberForm" class="row g-3">

      <!-- FULL NAME -->
      <div class="col-md-6">
        <label for="fullName" class="form-label">Full Name *</label>
        <input type="text" class="form-control" id="fullName" required />
        <div class="invalid-feedback">Full name is required.</div>
      </div>

      <!-- EMAIL -->
      <div class="col-md-6">
        <label for="email" class="form-label">Email Address *</label>
        <input type="email" class="form-control" id="email" required />
        <div class="invalid-feedback">A valid email is required.</div>
      </div>

      <!-- PHONE NUMBER -->
      <div class="col-md-6">
        <label for="phone" class="form-label">Phone Number (optional)</label>
        <input type="tel" class="form-control" id="phone" />
      </div>

      <!-- DATE OF SIGNUP -->
      <div class="col-md-6">
        <label for="signupDate" class="form-label">Date of Signup *</label>
        <input type="date" class="form-control" id="signupDate" required />
        <div class="invalid-feedback">Signup date is required.</div>
      </div>

      <!-- FAVORITE TEAM -->
      <div class="col-md-6">
        <label for="favoriteTeam" class="form-label">Favorite Team *</label>
        <select id="favoriteTeam" class="form-select" required>
          <option value="">Choose a team...</option>
          <option>Lakers</option>
          <option>Warriors</option>
          <option>Bucks</option>
          <option>Celtics</option>
          <option>Suns</option>
          <option>76ers</option>
          <option>Nuggets</option>
          <option>Heat</option>
        </select>
        <div class="invalid-feedback">Please select a team.</div>
      </div>

      <!-- PLAYERS TO TRACK (OPEN TEXT BOX) -->
      <div class="col-md-6">
        <label for="playersTrack" class="form-label">Players to Track</label>
        <textarea
          id="playersTrack"
          class="form-control"
          rows="3"
          placeholder="Example: LeBron James, Stephen Curry, Kevin Durant"
        ></textarea>
      </div>

      <!-- HIDDEN FIELD FOR EDITING -->
      <input type="hidden" id="editIndex" value="-1" />

      <!-- BUTTONS -->
      <div class="col-12">
        <button type="submit" class="btn btn-primary" id="submitBtn">Add Fan</button>
        <button type="button" class="btn btn-secondary d-none" id="cancelEditBtn">Cancel Edit</button>
      </div>
    </form>

    <hr class="my-5" />

    <!-- FAN TABLE -->
    <h2>Registered Fans</h2>

    <div class="table-responsive">